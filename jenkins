pipeline {
    agent any

    environment {
        SCANNER_HOME = tool 'Sonar-scanner'
    }

    stages {

        stage('Git Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Parnika110805/ML_PRoject.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                bat """
                ${SCANNER_HOME}\\bin\\sonar-scanner.bat ^
                -Dsonar.projectKey=ASD_Project ^
                -Dsonar.projectName=ASD_Project ^
                -Dsonar.sources=. ^
                -Dsonar.host.url=http://localhost:9000 ^
                -Dsonar.token=%SONAR_TOKEN%
                """
            }
        }

        stage('Dependency Check') {
            steps {
                dependencyCheck additionalArguments: '--scan ./',
                                odcInstallation: 'DP'

                dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t asd-project .'
            }
        }

        stage('Deploy Container') {
            steps {
                bat '''
                docker rm -f asd-project-container 2>nul
                docker run -d --name asd-project-container -p 5000:5000 asd-project
                '''
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'U', passwordVariable: 'P')]) {
                    bat '''
                    docker login -u %U% -p %P%
                    docker tag asd-project %U%/asd-project:latest
                    docker push %U%/asd-project:latest
                    '''
                }
            }
        }
    }
}
